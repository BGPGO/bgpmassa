# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/bgpmassa

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Z-API
ZAPI_WEBHOOK_SECRET=your-webhook-secret
ZAPI_CLIENT_TOKEN=                        # Seu Client-Token Z-API (se usar plano Business)

# ── Instâncias Z-API (adicione quantas precisar seguindo o padrão _n_) ─────
# Instância 1 — Operações
ZAPI_INSTANCE_1_NAME=Operações
ZAPI_INSTANCE_1_ID=
ZAPI_INSTANCE_1_TOKEN=

# Instância 2 — Financeiro
ZAPI_INSTANCE_2_NAME=Financeiro
ZAPI_INSTANCE_2_ID=
ZAPI_INSTANCE_2_TOKEN=

# Instância 3 — Fideliza
ZAPI_INSTANCE_3_NAME=Fideliza
ZAPI_INSTANCE_3_ID=
ZAPI_INSTANCE_3_TOKEN=

# Seed do admin inicial
SEED_ADMIN_EMAIL=admin@bgpmassa.com
