# =============================================================================
#  BGP Massa — Variáveis de Ambiente
#  Copie este arquivo para apps/api/.env e preencha os valores.
#  No Coolify: adicione cada variável diretamente no painel de Environment.
# =============================================================================

# ── Banco de dados ────────────────────────────────────────────────────────
# Supabase: use a connection string do painel Project Settings > Database
# IMPORTANTE: caracteres especiais na senha precisam ser URL-encoded
#   $ → %24   # → %23   & → %26   @ → %40   : → %3A
DATABASE_URL=postgresql://postgres:SENHA@db.SEU_PROJETO.supabase.co:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────
# Em produção: use o Redis interno do Coolify (ex: redis://redis:6379)
# ou um Redis externo (ex: Upstash)
REDIS_URL=redis://redis:6379

# ── JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=gere-um-secret-aqui-64-bytes-hex
JWT_REFRESH_SECRET=gere-outro-secret-aqui-64-bytes-hex
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Segredo para validar webhooks recebidos do Z-API
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ZAPI_WEBHOOK_SECRET=gere-um-secret-aqui

# ── Client-Token Z-API (plano Business — encontrado no painel Z-API)
ZAPI_CLIENT_TOKEN=

# ── Instâncias Z-API ──────────────────────────────────────────────────────
# Adicione quantas instâncias precisar seguindo o padrão ZAPI_INSTANCE_n_*
# ID e TOKEN: encontrados no painel Z-API de cada número
ZAPI_INSTANCE_1_NAME=Operações
ZAPI_INSTANCE_1_ID=
ZAPI_INSTANCE_1_TOKEN=

ZAPI_INSTANCE_2_NAME=Financeiro
ZAPI_INSTANCE_2_ID=
ZAPI_INSTANCE_2_TOKEN=

ZAPI_INSTANCE_3_NAME=Fideliza
ZAPI_INSTANCE_3_ID=
ZAPI_INSTANCE_3_TOKEN=

# ── URLs da aplicação ─────────────────────────────────────────────────────
# APP_URL: URL pública da API (usada para registrar webhooks no Z-API)
#   Coolify: ex https://api.bgpmassa.com.br
APP_URL=https://api.SEU_DOMINIO.com.br

# PORT: porta interna da API (deixe 3001, o Coolify faz o proxy)
PORT=3001

NODE_ENV=production

# CORS_ORIGIN: URL do frontend (usada para permitir chamadas cross-origin)
#   Coolify: ex https://app.bgpmassa.com.br
CORS_ORIGIN=https://app.SEU_DOMINIO.com.br

# ── Usuários adicionais (seed inicial — remova após primeiro deploy) ───────
# Cria usuários no Supabase automaticamente na primeira inicialização.
# Use upsert — rodar seed novamente NÃO sobrescreve quem já existe.
# SEED_USER_1_NAME=João Silva
# SEED_USER_1_EMAIL=joao@bgpmassa.com
# SEED_USER_1_PASSWORD=senha-temporaria-forte
# SEED_USER_1_ROLE=AGENT

# SEED_USER_2_NAME=Maria Admin
# SEED_USER_2_EMAIL=maria@bgpmassa.com
# SEED_USER_2_PASSWORD=senha-temporaria-forte
# SEED_USER_2_ROLE=ADMIN
