# ── BGP Massa Web — Variáveis de Ambiente ─────────────────────────────────
#
# Desenvolvimento local: copie para .env.local
# Produção (Coolify): configure como Build Arguments no serviço do web:
#   NEXT_PUBLIC_API_URL    → URL pública da API  (ex: https://api.bgpmassa.com.br)
#   NEXT_PUBLIC_SOCKET_URL → mesma URL da API    (ex: https://api.bgpmassa.com.br)
#
# ATENÇÃO: estas variáveis são "baked" no bundle Next.js em tempo de build.
# Alterar só em runtime NÃO funciona — é necessário rebuildar.
# ──────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
